# Variables de entorno para desplegar api-gateway en Railway.
# Este servicio no tiene base de datos propia, asi que no necesita
# DATABASE_URL/USERNAME/PASSWORD. Es el unico al que le corresponde
# generar un dominio publico permanente en Railway.

SPRING_PROFILES_ACTIVE=remote
SPRING_CONFIG_IMPORT=optional:configserver:http://config-server.railway.internal:8888/
EUREKA_URL=http://eureka-server.railway.internal:8761/eureka/
