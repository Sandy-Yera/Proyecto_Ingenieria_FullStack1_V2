# Variables de entorno para desplegar ms-auth en Railway.
# Copia este bloque completo en el "Raw Editor" de variables del servicio
# y reemplaza los placeholders <...> con los valores reales del plugin MySQL
# y del dominio publico de api-gateway una vez desplegado.

SPRING_PROFILES_ACTIVE=remote
SPRING_CONFIG_IMPORT=optional:configserver:http://config-server.railway.internal:8888/
EUREKA_URL=http://eureka-server.railway.internal:8761/eureka/
DATABASE_URL=jdbc:mysql://<MYSQL_HOST>:<MYSQL_PORT>/db_service_auth?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
DATABASE_USERNAME=<MYSQL_USER>
DATABASE_PASSWORD=<MYSQL_PASSWORD>
APP_GATEWAY_URL=https://<api-gateway-domain>
